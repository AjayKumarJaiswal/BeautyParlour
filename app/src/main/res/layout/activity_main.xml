<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cream"
    tools:context=".MainActivity">

    <!-- FIXED TOP HEADER -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <LinearLayout
            android:id="@+id/fixedTopBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/top_bg"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/llHomeBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/ivHeaderIcon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@string/location_text"
                        android:src="@android:drawable/ic_menu_mylocation"
                        app:tint="@color/black" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvHeaderTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/location_text"
                            android:textColor="@color/black"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvUserBio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Beauty Enthusiast"
                            android:textColor="@color/text_gray"
                            android:textSize="10sp"
                            android:maxLines="1"
                            android:ellipsize="end" />

                        <TextView
                            android:id="@+id/tvUserDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Passionate about style"
                            android:textColor="@color/text_gray"
                            android:textSize="9sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:visibility="gone" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivHeaderArrow"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:contentDescription="@null"
                        android:src="@android:drawable/arrow_down_float" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/ivSearchIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="16dp"
                        android:contentDescription="@string/search"
                        android:src="@android:drawable/ic_menu_search"
                        android:visibility="gone"
                        app:tint="@color/black" />

                    <FrameLayout
                        android:id="@+id/flProfile"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_profile_circle">

                        <TextView
                            android:id="@+id/tvProfileIcon"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="@string/profile_initials"
                            android:textColor="@color/black"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </FrameLayout>
                </LinearLayout>
            </RelativeLayout>

            <LinearLayout
                android:id="@+id/searchBarContainer"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_search_bar"
                android:elevation="2dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/search_hint" />

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:background="@null"
                    android:hint="@string/search_hint_home"
                    android:importantForAutofill="no"
                    android:inputType="text"
                    android:textColorHint="@color/search_hint"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- PAGE 1: HOME -->
            <LinearLayout
                android:id="@+id/pageHome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:id="@+id/btnHairCut"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/bg_category_icon" android:contentDescription="@string/cat_haircut" android:padding="12dp" android:src="@android:drawable/ic_menu_edit" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/cat_haircut" android:textColor="@color/text_main" android:textSize="11sp" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnMakeup"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/bg_category_icon" android:contentDescription="@string/cat_makeup" android:padding="12dp" android:src="@android:drawable/ic_menu_gallery" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/cat_makeup" android:textColor="@color/text_main" android:textSize="11sp" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnFacial"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/bg_category_icon" android:contentDescription="@string/cat_facial" android:padding="12dp" android:src="@android:drawable/ic_menu_camera" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/cat_facial" android:textColor="@color/text_main" android:textSize="11sp" android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnBridal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView android:layout_width="52dp" android:layout_height="52dp" android:background="@drawable/bg_category_icon" android:contentDescription="@string/cat_bridal" android:padding="12dp" android:src="@android:drawable/btn_star_big_on" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="@string/cat_bridal" android:textColor="@color/text_main" android:textSize="11sp" android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_banner_gradient" android:gravity="center_vertical" android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/promo_text" android:textColor="@color/black" android:textSize="20sp" android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Trending Section Header -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp">
                    <TextView
                        android:id="@+id/tvTrendingTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/trending_title"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvViewAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="@string/view_all"
                        android:textColor="#00838F"
                        android:textStyle="bold" />
                </RelativeLayout>

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/trendingViewPager"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="12dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvAllTrending"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- SECTION: SALON DETAIL -->
            <LinearLayout
                android:id="@+id/sectionSalonDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="40dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="2dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                        <FrameLayout android:layout_width="match_parent" android:layout_height="220dp">
                            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:background="#E0E0E0" android:scaleType="centerCrop" />
                            <ImageView android:id="@+id/ivBackFromDetail" android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="16dp" android:background="@drawable/bg_category_icon" android:backgroundTint="#80FFFFFF" android:padding="8dp" android:rotation="180" android:src="@android:drawable/ic_menu_revert" android:contentDescription="@string/back" />
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="end"
                                android:layout_margin="16dp">
                                <ImageView
                                    android:id="@+id/ivSalonChat"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:background="@drawable/bg_category_icon"
                                    android:backgroundTint="#80FFFFFF" android:padding="8dp"
                                    android:src="@android:drawable/stat_notify_chat" app:tint="@color/black" />
                            </LinearLayout>
                        </FrameLayout>
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/parlour_name_detail" android:textColor="@color/black" android:textSize="22sp" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/rating_text" android:textSize="14sp" android:textColor="@color/black" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <LinearLayout android:id="@+id/pageHairCut" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp" android:visibility="gone">
                    <include android:id="@+id/cardHairCut1" layout="@layout/item_service_card" />
                    <include android:id="@+id/cardHairCut2" layout="@layout/item_service_card" />
                    <include android:id="@+id/cardHairCut3" layout="@layout/item_service_card" />
                    <include android:id="@+id/cardHairCut4" layout="@layout/item_service_card" />
                    <include android:id="@+id/cardHairCut5" layout="@layout/item_service_card" />
                </LinearLayout>
                <LinearLayout android:id="@+id/pageMakeup" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp" android:visibility="gone">
                    <include android:id="@+id/cardMakeup1" layout="@layout/item_service_card" />
                    <include android:id="@+id/cardMakeup2" layout="@layout/item_service_card" />
                    <include android:id="@+id/cardMakeup3" layout="@layout/item_service_card" />
                    <include android:id="@+id/cardMakeup4" layout="@layout/item_service_card" />
                    <include android:id="@+id/cardMakeup5" layout="@layout/item_service_card" />
                </LinearLayout>
                <LinearLayout android:id="@+id/pageFacial" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp" android:visibility="gone">
                    <include android:id="@+id/cardFacial1" layout="@layout/item_service_card" />
                    <include android:id="@+id/cardFacial2" layout="@layout/item_service_card" />
                    <include android:id="@+id/cardFacial3" layout="@layout/item_service_card" />
                    <include android:id="@+id/cardFacial4" layout="@layout/item_service_card" />
                    <include android:id="@+id/cardFacial5" layout="@layout/item_service_card" />
                </LinearLayout>
                <LinearLayout android:id="@+id/pageBridal" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp" android:visibility="gone">
                    <include android:id="@+id/cardBridal1" layout="@layout/item_service_card" />
                    <include android:id="@+id/cardBridal2" layout="@layout/item_service_card" />
                    <include android:id="@+id/cardBridal3" layout="@layout/item_service_card" />
                    <include android:id="@+id/cardBridal4" layout="@layout/item_service_card" />
                    <include android:id="@+id/cardBridal5" layout="@layout/item_service_card" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottomNavBarContainer"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:elevation="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp">
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@android:drawable/ic_menu_view" android:contentDescription="@null" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/my_cart_count" android:textColor="@color/black" android:textSize="10sp" />
        </LinearLayout>
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="28dp" android:gravity="center" android:orientation="vertical">
            <ImageView android:layout_width="26dp" android:layout_height="26dp" android:src="@android:drawable/ic_menu_agenda" android:contentDescription="@null" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/my_order_count" android:textColor="@color/black" android:textSize="10sp" />
        </LinearLayout>
        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_tag" android:backgroundTint="#F5F5F5" android:gravity="center_vertical" android:paddingHorizontal="16dp" android:paddingVertical="10dp">
            <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_mylocation" app:tint="@color/black" android:contentDescription="@null" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:text="@string/salon_loc_btn" android:textColor="@color/black" android:textSize="12sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>